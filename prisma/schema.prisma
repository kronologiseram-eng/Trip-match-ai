datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Table untuk simpan data Job yang di-scrap oleh robot AI
model Job {
  id          String   @id @default(uuid())
  truckType   String   // Saiz lori (1 Tan, 3 Tan, 10 Tan)
  origin      String   // Lokasi pickup (Penang, KL, dll)
  destination String   // Lokasi dropoff
  date        String   // Tarikh/masa post di Facebook
  phone       String   // Nombor telefon pemilik barang
  createdAt   DateTime @default(now())
}
